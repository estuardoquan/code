resource "proxmox_vm_qemu" "f44_se_0" {
        name = "f44-se-0"
        description = "Fedora Server 44"
        vmid = 300
        target_node = "hades"

        bios = "ovmf"
        agent = 1
        clone = "f44-se"
        memory = 4092
        scsihw = "virtio-scsi-pci"
        automatic_reboot = true
        
        cpu {
            sockets = 1
            cores = 4
        }

        network {
            id = 0
            model  = "virtio"
            bridge = "vmbr0"
        }
        
        disks {
            scsi {
                scsi0 {
                    disk {
                        storage = "nas"
                        size    = "50G" 
                    }
                }
            }
            ide {
                ide0 {
                    cloudinit {
                        storage = "nas"
                    }
                }
            }
        }

        efidisk {
            storage = "nas"
            efitype = "4m" 
        }

        os_type = "cloud_init"
        ciupgrade  = true
        skip_ipv6  = true

        cicustom = "user=nas:snippets/f44-user.yaml"
}
